# Copiar a .env.local (no subir a Git)
# Público OK:
NEXT_PUBLIC_SITE_URL=https://stg.hechomadera.com

# WhatsApp: número completo con código país, sin + ni espacios (ej. 573012890552)
NEXT_PUBLIC_WHATSAPP_PHONE=

# Banner promocional (opcional). En Vercel: PROMO_ENABLED=true + texto
# NEXT_PUBLIC_PROMO_ENABLED=false
# NEXT_PUBLIC_PROMO_TEXT=
# NEXT_PUBLIC_PROMO_LINK=/contacto

# Contacto por email (Resend — https://resend.com). Manual en Vercel:
# RESEND_API_KEY=
# Dónde recibes los avisos (puede ser Gmail):
# CONTACT_TO_EMAIL=infohechomadera@gmail.com
# Remitente: debe ser correo del dominio verificado en Resend (no @gmail.com):
# RESEND_FROM="Hechomadera <info@hechomadera.com>"

# Mercado Pago — solo servidor (Vercel). Ver docs/MERCADOPAGO.md
# MERCADOPAGO_ACCESS_TOKEN=
# En producción, /pago/prueba devuelve 404 salvo que pongas:
# ENABLE_PAYMENT_TEST_PAGE=true
# Webhook (opcional, validación avanzada):
# MERCADOPAGO_WEBHOOK_SECRET=
# Debug temporal para endpoint /api/payments/webhook-events (no compartir):
# DEBUG_WEBHOOK_TOKEN=
# Persistencia opcional de eventos webhook (Upstash Redis):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
