# ============================================================
# Hechomadera — Variables de entorno
# Copiar a .env.local para desarrollo. NO subir a Git.
# En Vercel: Settings → Environment Variables
# ============================================================

# ------------------------------------------------------------
# SITIO (requerido)
# Staging (Vercel preview):  https://stg.hechomadera.com
# Producción (dominio real): https://hechomadera.com
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://hechomadera.com

# ------------------------------------------------------------
# WHATSAPP (requerido para botones WA)
# Número Colombia completo, sin + ni espacios. Ej: 573012890552
# ------------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_PHONE=

# ------------------------------------------------------------
# BANNER PROMOCIONAL (opcional)
# Activar con NEXT_PUBLIC_PROMO_ENABLED=true
# ------------------------------------------------------------
# NEXT_PUBLIC_PROMO_ENABLED=false
# NEXT_PUBLIC_PROMO_TEXT=
# NEXT_PUBLIC_PROMO_LINK=/contacto

# ------------------------------------------------------------
# MERCADO PAGO (requerido para checkout)
# Token de PRUEBA:      TEST-...
# Token de PRODUCCION:  APP_USR-...
# Obtener en: mercadopago.com.co → Tus integraciones → Credenciales
# ------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=

# Webhook: URL a registrar en MP → https://hechomadera.com/api/payments/mercadopago/webhook
# Secret: clave que MP firma en cada notificación (panel MP → Webhooks)
MERCADOPAGO_WEBHOOK_SECRET=

# PRODUCCION: activar validación de firma (rechaza webhooks sin firma válida)
# Dejar en false mientras pruebas, cambiar a true al pasar a producción real
MERCADOPAGO_WEBHOOK_ENFORCE=false

# Activar la página de prueba de pago (/pago/prueba) en producción (normalmente false)
# ENABLE_PAYMENT_TEST_PAGE=false

# Token para endpoint debug /api/payments/webhook-events (no compartir)
# DEBUG_WEBHOOK_TOKEN=

# ------------------------------------------------------------
# RESEND — Email de contacto (requerido para formulario de contacto)
# Verificar dominio hechomadera.com en resend.com antes de usar
# ------------------------------------------------------------
RESEND_API_KEY=
# Correo donde recibes los avisos (puede ser Gmail)
CONTACT_TO_EMAIL=infohechomadera@gmail.com
# Remitente: DEBE ser del dominio verificado en Resend (no @gmail.com)
RESEND_FROM=Hechomadera <info@hechomadera.com>

# ------------------------------------------------------------
# UPSTASH REDIS — Persistencia de órdenes y webhook-events
# Crear en upstash.com → Redis → REST API
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ------------------------------------------------------------
# ADMIN — Panel interno de órdenes (/admin)
# Token fuerte (mínimo 32 chars). Guardar en lugar seguro.
# ------------------------------------------------------------
ADMIN_API_TOKEN=
